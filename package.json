{
  "name": "agent-manager-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Agent 配置管理桌面端 MVP",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on tcp:5173 && npm run build:main && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "build:main": "tsc -p tsconfig.electron.json && node scripts/copy-main-assets.js",
    "build": "npm run build:main && vite build",
    "start": "electron .",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "@iarna/toml": "2.2.5",
    "fs-extra": "11.2.0",
    "gray-matter": "4.0.3",
    "lucide-react": "0.468.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "yaml": "2.3.4",
    "zod": "3.22.4"
  },
  "devDependencies": {
    "@types/fs-extra": "11.0.4",
    "@types/node": "18.19.3",
    "@types/react": "18.2.45",
    "@types/react-dom": "18.2.18",
    "@vitejs/plugin-react": "4.2.1",
    "concurrently": "8.2.2",
    "cross-env": "7.0.3",
    "electron": "28.1.0",
    "typescript": "5.3.3",
    "vite": "4.5.1",
    "wait-on": "7.2.0"
  }
}
